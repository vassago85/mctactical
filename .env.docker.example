# Copy this file to `.env` in the same folder as docker-compose.yml (Compose loads `.env` automatically).

# --- Data directory (host) → mounted as /app/data in the API container (huntex.db + pdfs) ---
# Local: leave unset to use ./data next to docker-compose.yml, or set e.g. MCTACTICAL_DATA_DIR=./data
# Linux server: MCTACTICAL_DATA_DIR=/opt/mctactical
# API runs as UID 1654 (dotnet non-root). If you get permission errors on Linux:
#   sudo mkdir -p /opt/mctactical/pdfs && sudo chown -R 1654:1654 /opt/mctactical
# MCTACTICAL_DATA_DIR=/opt/mctactical

WEB_PORT=8080
PUBLIC_BASE_URL=http://localhost:8080

# API: Production = no Swagger on /swagger (set to Development only for local API debugging in Docker).
# ASPNETCORE_ENVIRONMENT=Development

# --- Production (e.g. Nginx Proxy Manager) ---
# Map host port (e.g. 8095) → web container 80: WEB_PORT=8095
# PUBLIC_BASE_URL must be the exact URL customers use (invoice email links):
# PUBLIC_BASE_URL=https://your-domain.example

# Required in production: at least 32 random characters (never commit real values to git)
JWT_KEY=

# First owner: created once on API startup if both set (10+ chars, upper, lower, digit, symbol)
OWNER_EMAIL=
OWNER_PASSWORD=

# Optional Mailgun
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM=MC Tactical POS <sales@mctactical.co.za>
