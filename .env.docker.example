# Copy to .env.docker and adjust. Docker Compose reads this file automatically if named .env in same folder as docker-compose.yml.
# Rename: copy .env.docker.example to .env next to docker-compose.yml

WEB_PORT=8080
PUBLIC_BASE_URL=http://localhost:8080

# --- Production (Nginx Proxy Manager) ---
# Proxy host: mctactical.charsleydigital.co.za → Forward 41.72.157.26:8095 (HTTP to backend is fine if NPM terminates SSL).
# On the server, map host port 8095 to this stack’s web container, e.g. WEB_PORT=8095 in .env
# PUBLIC_BASE_URL must be the URL users open in the browser (used for invoice / public links):
# PUBLIC_BASE_URL=https://mctactical.charsleydigital.co.za
# In NPM: add SSL (Let’s Encrypt), enable “Force SSL” / HTTP→HTTPS. The app nginx also redirects when
# X-Forwarded-Proto is http. Optional “Websockets” if you add real-time features later.

# Required for production: at least 32 random characters
JWT_KEY=

# First owner is created on API startup only if both are set (10+ char password, mixed case, digit, symbol).
OWNER_EMAIL=
OWNER_PASSWORD=

# Optional Mailgun
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM=MC Tactical POS <sales@mctactical.co.za>
