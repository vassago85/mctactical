# Copy to .env (gitignored) before running `docker compose -f docker-compose.local.yml up`.
# All values are required — docker-compose.local.yml now refuses to start without them.

# 32+ char random string (e.g. `openssl rand -base64 48`)
JWT_KEY=

# Optional issuer / audience strings (default: LocalPosDev)
# JWT_ISSUER=LocalPosDev
# JWT_AUDIENCE=LocalPosDev

# Initial owner login created on first boot
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=ChangeMeImmediately!
